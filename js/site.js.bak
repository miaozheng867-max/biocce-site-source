var IP_LANG_MAP = {
    CN: 'zh', TW: 'zh', HK: 'zh',
    US: 'en', GB: 'en', AU: 'en', CA: 'en', SG: 'en', IN: 'en',
    RU: 'ru', UA: 'ru', BY: 'ru', KZ: 'ru'
};

function __(key) {
    var dict = TRANSLATIONS[currentLang];
    return (dict && dict[key] !== undefined) ? dict[key] : key;
}

function translatePage(lang) {
    currentLang = lang;
    // Translate text nodes
    var els = document.querySelectorAll('[data-i18n]');
    for (var i = 0; i < els.length; i++) {
        var key = els[i].getAttribute('data-i18n');
        els[i].textContent = __(key);
    }
    // Translate placeholders
    var phs = document.querySelectorAll('[data-i18n-placeholder]');
    for (i = 0; i < phs.length; i++) {
        var key = phs[i].getAttribute('data-i18n-placeholder');
        phs[i].setAttribute('placeholder', __(key));
    }
    // Update language switch button
    var btn = document.getElementById('lang-current');
    if (btn) {
        var li = LANG_MAP[currentLang];
        btn.innerHTML = li.flag + ' ' + li.label + ' <span class="dropdown-arrow">\u25BE</span>';
    }
    // Update dropdown active state
    var menuLinks = document.querySelectorAll('.lang-menu a');
    for (i = 0; i < menuLinks.length; i++) {
        menuLinks[i].classList.toggle('active', menuLinks[i].dataset.lang === currentLang);
    }
}

function detectLanguageByIP() {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', 'https://ipapi.co/json/', true);
    xhr.onload = function() {
        try {
            var data = JSON.parse(xhr.responseText);
            var country = data.country_code;
            var detectedLang = IP_LANG_MAP[country] || 'en';
            var saved = localStorage.getItem('biocce_lang');
            if (!saved) translatePage(detectedLang);
        } catch(e) {}
    };
    xhr.onerror = function() {
        var saved = localStorage.getItem('biocce_lang');
        if (saved) translatePage(saved);
    };
    xhr.send();
}

function setLanguage(code, isManual) {
    if (!LANG_MAP[code]) code = 'en';
    translatePage(code);
    if (isManual) localStorage.setItem('biocce_lang', code);
}

function getRelatedProducts(currentModel, cat, limit) {
    if (!limit) limit = 3;
    var sameCat = PRODUCT_DB.filter(function(p) { return p.cat === cat && p.model !== currentModel; });
    return sameCat.sort(function() { return 0.5 - Math.random(); }).slice(0, limit);
}

function getProductsByCategory(catId) {
    return PRODUCT_DB.filter(function(p) { return p.cat === catId; });
}

function getProductsBySubcategory(catId, subcat) {
    return PRODUCT_DB.filter(function(p) { return p.cat === catId && p.subcat === subcat; });
}

// ==================== 初始化 ====================
document.addEventListener('DOMContentLoaded', function() {
    // Search
    var searchInput = document.getElementById('search-input');
    if (searchInput) {
        var debounceTimer;
        searchInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function() {
                renderSearchResults(performSearch(searchInput.value));
            }, 200);
        });
        searchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeSearch();
        });
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.search-wrapper')) closeSearch();
        });
    }

    // Language menu toggle
    var langToggle = document.getElementById('lang-toggle');
    var langMenu = document.getElementById('lang-menu');
    if (langToggle && langMenu) {
        langToggle.addEventListener('click', function(e) {
            e.stopPropagation();
            langMenu.classList.toggle('active');
        });
        document.addEventListener('click', function() {
            langMenu.classList.remove('active');
        });
    }

    // Language menu links
    var langLinks = document.querySelectorAll('.lang-menu a');
    for (var i = 0; i < langLinks.length; i++) {
        langLinks[i].addEventListener('click', function(e) {
            e.preventDefault();
            var code = this.dataset.lang;
            langMenu.classList.remove('active');
            setLanguage(code, true);
        });
    }

    // Init language
    var savedLang = localStorage.getItem('biocce_lang');
    if (savedLang && LANG_MAP[savedLang]) {
        translatePage(savedLang);
    } else if (!localStorage.getItem('biocce_lang_detected')) {
        detectLanguageByIP();
        localStorage.setItem('biocce_lang_detected', '1');
    }

    // Mobile nav toggle
    var navToggle = document.querySelector('.nav-toggle');
    var nav = document.querySelector('.nav');
    if (navToggle && nav) {
        navToggle.addEventListener('click', function() {
            nav.classList.toggle('open');
        });
    }

    // Mobile dropdowns
    var toggles = document.querySelectorAll('.nav .dropdown-toggle');
    for (i = 0; i < toggles.length; i++) {
        (function(t) {
            t.addEventListener('click', function(e) {
                if (window.innerWidth <= 768) {
                    this.parentElement.classList.toggle('open');
                }
            });
        })(toggles[i]);
    }
});
