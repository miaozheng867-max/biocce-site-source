// ==================== 搜索功能 ====================
function performSearch(query) {
    query = query.trim().toLowerCase();
    if (query.length < 1) return [];
    return PRODUCT_DB.filter(function(p) {
        var searchText = (p.model + ' ' + p.name + ' ' + p.subcat + ' ' + p.desc + ' ' + p.keywords.join(' ')).toLowerCase();
        return query.split(/\s+/).every(function(k) { return searchText.indexOf(k) >= 0; });
    }).slice(0, 20);
}

function renderSearchResults(results) {
    var panel = document.getElementById('search-results');
    if (!panel) return;
    if (results.length === 0) {
        panel.innerHTML = '<div class="search-empty">' + __('No products found matching your search.') + '</div>';
        panel.classList.add('active');
        return;
    }
    panel.innerHTML = results.map(function(r) {
        return '<a href="' + r.url + '" class="search-item" onclick="closeSearch()"><span class="search-model">' +
            r.model + '</span><span class="search-name">' + r.name + '</span><span class="search-desc">' +
            r.subcat + ' - ' + r.desc + '</span></a>';
    }).join('');
    panel.classList.add('active');
}

function closeSearch() {
    var panel = document.getElementById('search-results');
    var input = document.getElementById('search-input');
    if (panel) panel.classList.remove('active');
    if (input) input.value = '';
}

